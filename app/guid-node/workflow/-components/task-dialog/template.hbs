{{#if @open}}
    <div class="modal fade in workflow-task-dialog" tabindex="-1" role="dialog" aria-modal="true" style="display: block; z-index: 1030;">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" aria-label={{t 'workflow.console.close'}} {{on "click" @onClose}}>
                        <span aria-hidden="true">&times;</span>
                    </button>
                    <h4 class="modal-title">{{if this.taskTitle this.taskTitle (t 'workflow.console.tasks.dialog.titleFallback')}}</h4>
                </div>
                <div class="modal-body task-dialog__body">
                    {{#if @error}}
                        <div class="alert alert-danger" role="alert">
                            {{@error}}
                        </div>
                    {{/if}}
                    {{#if @actionError}}
                        <div class="alert alert-danger" role="alert">
                            {{@actionError}}
                        </div>
                    {{/if}}
                    {{#if @isLoading}}
                        <p class="text-muted">
                            <i class="fa fa-spinner fa-spin"></i>
                            {{t 'workflow.console.tasks.dialog.loading'}}
                        </p>
                    {{else if this.hasTask}}
                        <div class="task-dialog__layout">
                            <GuidNode::Workflow::-Components::ProgressSidebar
                                @form={{@task.form}}
                                @variables={{@task.variables}}
                                @wizardSteps={{if this.wizardNav this.wizardNav.progressSteps}}
                            />
                            <div class="task-dialog__content">
                                <dl class="dl-horizontal">
                                    <dt>{{t 'workflow.console.tasks.columns.task'}}</dt>
                                    <dd>{{or this.taskTitle (t 'workflow.console.tasks.dialog.untitled')}}</dd>
                                    <dt>{{t 'workflow.console.tasks.columns.assignee'}}</dt>
                                    <dd>{{this.assigneeLabel}}</dd>
                                    <dt>{{t 'workflow.console.tasks.dialog.startedAt'}}</dt>
                                    <dd>{{or @task.created (t 'workflow.console.tasks.dialog.notAvailable')}}</dd>
                                    <dt>{{t 'workflow.console.tasks.dialog.dueAt'}}</dt>
                                    <dd>{{or @task.due (t 'workflow.console.tasks.dialog.notAvailable')}}</dd>
                                </dl>

                                {{#if @task.description}}
                                    <p class="text-muted">{{@task.description}}</p>
                                {{/if}}

                                {{#unless this.canComplete}}
                                    <div class="alert alert-warning" role="alert">
                                        {{t 'workflow.console.tasks.dialog.notAssigned'}}
                                    </div>
                                {{/unless}}

                                <GuidNode::Workflow::-Components::TaskForm
                                    @form={{@task.form}}
                                    @variables={{@task.variables}}
                                    @node={{@node}}
                                    @taskId={{@task.id}}
                                    @onChange={{this.handleFormChange}}
                                    @onSubmit={{this.handleSubmit}}
                                    @onWizardNavigationChange={{this.handleWizardNavigationChange}}
                                />
                            </div>
                        </div>
                    {{else}}
                        <p class="text-muted">{{t 'workflow.console.tasks.dialog.noTask'}}</p>
                    {{/if}}
                </div>
                <div class="modal-footer">
                    {{#if (and this.hasTask this.isWizardMode this.wizardNav)}}
                        {{#if (and this.wizardNav.allowBack (not this.wizardNav.isFirstPage))}}
                            <button
                                type="button"
                                class="btn btn-default"
                                disabled={{@isSubmitting}}
                                {{on "click" this.wizardNav.goBack}}
                            >
                                {{t 'workflow.console.tasks.dialog.wizard.back'}}
                            </button>
                        {{/if}}
                        {{#if this.wizardNav.isLastPage}}
                            <button
                                type="button"
                                class="btn btn-primary"
                                disabled={{or (not this.canComplete) (not this.wizardNav.canGoNext) @isSubmitting}}
                                {{on "click" this.wizardNav.submit}}
                            >
                                {{#if @isSubmitting}}
                                    <i class="fa fa-spinner fa-spin"></i>
                                    {{t 'workflow.console.tasks.dialog.submitting'}}
                                {{else}}
                                    {{t 'workflow.console.tasks.dialog.submit'}}
                                {{/if}}
                            </button>
                        {{else}}
                            <button
                                type="button"
                                class="btn btn-primary"
                                disabled={{not this.wizardNav.canGoNext}}
                                {{on "click" this.wizardNav.goNext}}
                            >
                                {{t 'workflow.console.tasks.dialog.wizard.next'}}
                            </button>
                        {{/if}}
                    {{else if (and this.hasTask (not this.isWizardMode))}}
                        <button
                            type="button"
                            class="btn btn-primary"
                            disabled={{or (not this.canComplete) (not this.isFormValid)}}
                            {{on "click" this.handleSubmit}}
                            data-test-task-dialog-submit
                        >
                            {{#if @isSubmitting}}
                                <i class="fa fa-spinner fa-spin"></i>
                                {{t 'workflow.console.tasks.dialog.submitting'}}
                            {{else}}
                                {{if this.isFinalStep (t 'workflow.console.tasks.dialog.submit') (t 'workflow.console.tasks.dialog.next')}}
                            {{/if}}
                        </button>
                    {{/if}}
                    <button type="button" class="btn btn-default" {{on "click" @onClose}}>
                        {{t 'workflow.console.close'}}
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade in" style="z-index: 1020;"></div>
{{/if}}
