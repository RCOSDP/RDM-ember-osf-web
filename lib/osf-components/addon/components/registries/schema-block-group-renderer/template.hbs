{{#if this.isFieldsetGroup}}
    <fieldset local-class='Fieldset'>
        {{#each this.nonOptionBlocks as |block|}}
            <Registries::SchemaBlockRenderer
                @schemaBlock={{block}}
                @optionBlocks={{this.optionBlocks}}
                @uniqueID={{this.uniqueID}}
                @renderStrategy={{@renderStrategy}}
                @isRequired={{this.isRequired}}
                @isFieldsetGroup={{true}}
                @inputBlockUI={{this.inputBlockUI}}
                @tagDefs={{@tagDefs}}
                @changeset={{@changeset}}
                @checkMarkKeys={{@checkMarkKeys}}
            />
        {{/each}}
    </fieldset>
{{else}}
    {{#each this.nonOptionBlocks as |block|}}
        <Registries::SchemaBlockRenderer
            @schemaBlock={{block}}
            @optionBlocks={{this.optionBlocks}}
            @uniqueID={{this.uniqueID}}
            @renderStrategy={{@renderStrategy}}
            @isRequired={{this.isRequired}}
            @isFieldsetGroup={{false}}
            @inputBlockUI={{this.inputBlockUI}}
            @tagDefs={{@tagDefs}}
            @changeset={{@changeset}}
            @checkMarkKeys={{@checkMarkKeys}}
        />
    {{/each}}
{{/if}}
