{{#let (component 'registries/schema-block-renderer/editable/mapper'
    changeset=this.pageManager.changeset
    node=@node
    onInput=@onInput
    metadataChangeset=this.draftManager.metadataChangeset
    metadataNodeErad=this.draftManager.metadataNodeErad
    metadataNodeProject=this.draftManager.metadataNodeProject
    onMetadataInput=@onMetadataInput
    draftManager=this.draftManager
) as |baseStrategy|}}
    <Registries::UiVisualItems
        @items={{this.visualItems}}
        @baseStrategy={{baseStrategy}}
        @tagDefs={{this.tagDefs}}
        @changeset={{this.pageManager.changeset}}
        @isTopLevel={{true}}
    />
{{/let}}
