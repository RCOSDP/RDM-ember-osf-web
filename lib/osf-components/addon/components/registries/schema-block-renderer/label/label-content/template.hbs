{{assert 'Registries::SchemaBlockRenderer::Label::LabelContent requires a @schemaBlock' @schemaBlock}}
<p
    ...attributes
    local-class='DisplayText {{if this.displayTextOverride 'SubLabel'}}'>
    {{~#if (eq this.itemMarker 'circle')~}}{{this.circleMarker}} {{~/if~}}
    {{~this.localizedDisplayText~}}
    {{~#if (and @isRequired (not @readonly))~}}
        <span local-class='Required'>*</span>
    {{~/if~}}
</p>
{{~#each this.itemTags as |tag|~}}
    <span tabindex='-1' {{on 'click' this.preventLabelFocus}}>
        <span local-class='TagBadge'>{{~tag.localizedText~}}</span>
        {{~#if tag.info~}}
            <BsPopover @triggerEvents={{array 'focus'}}>
                {{tag.info}}
            </BsPopover>
        {{~/if~}}
    </span>
{{~/each~}}
{{~#if this.itemInfo~}}
    <span local-class='InfoMark' tabindex='-1' {{on 'click' this.preventLabelFocus}}>
        <FaIcon @icon='info-circle' />
        <BsPopover @triggerEvents={{array 'focus'}}>
            {{this.itemInfo}}
        </BsPopover>
    </span>
{{~/if~}}
{{~#if (and @changeset @checkMarkKeys)~}}
    <Registries::ValueCheckMark
        @changeset={{@changeset}}
        @keys={{@checkMarkKeys}}
    />
{{~/if~}}
{{#if @isEditableForm}}
    <div local-class='HelpText'>
        {{#each this.localizedHelpTextLines as |lineParts|}}
            <p local-class='HelpTextLine'>
                {{#each lineParts as |part|}}
                    {{#if part.isLink}}
                        <a
                            href={{part.content}}
                            target='_blank'
                            rel='noopener noreferrer'
                        >
                            {{part.content}}
                        </a>
                    {{else}}
                        {{part.content}}
                    {{/if}}
                {{/each}}
            </p>
        {{/each}}
    </div>

    {{#if @schemaBlock.exampleText}}
        <OsfButton
            local-class='ExampleButton'
            @type='link'
            @onClick={{action this.toggleShouldShowExample}}
        >
            {{#if this.shouldShowExample}}
                {{t 'osf-components.registries.schema-block-renderer/label.hideExample'}}
            {{else}}
                {{t 'osf-components.registries.schema-block-renderer/label.showExample'}}
            {{/if}}
        </OsfButton>
        {{#if this.shouldShowExample}}
            <p local-class='ExampleText'>
                {{~this.schemaBlock.exampleText~}}
            </p>
        {{/if}}
    {{/if}}
{{else}}
    {{#if @draftManager}}
        <OsfLink
            aria-label={{t 'osf-components.registries.schema-block-renderer/label.editButtonAriaLabel' questionLabel=@schemaBlock.displayText}}
            @route='registries.drafts.draft.page'
            @models={{array @draftManager.draftId @schemaBlock.pageRouteParam}}
            @fragment={{@schemaBlock.elementId}}
        >
            {{#if (not @schemaBlock.readonly) }}
                <FaIcon @icon='edit' />
            {{/if}}
        </OsfLink>
    {{/if}}
{{/if}}